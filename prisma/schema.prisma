generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tool {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  developer     String
  description   String
  longDescription String?
  logoUrl       String?
  thumbnailUrl  String?
  website       String
  affiliateUrl  String?
  rating        Float    @default(0)
  reviewCount   Int      @default(0)
  views         Int      @default(0)
  clicks        Int      @default(0)
  bookmarks     Int      @default(0)
  isFeatured    Boolean  @default(false)
  isSponsored   Boolean  @default(false)
  isActive      Boolean  @default(true)
  platforms     String   @default("Web")
  pros          String?
  cons          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  categories    ToolCategory[]
  industries    ToolIndustry[]
  tags          ToolTag[]
  pricingPlans  PricingPlan[]
  features      Feature[]
  useCases      UseCase[]
  reviews       Review[]
  toolViews     ToolView[]
  toolClicks    ToolClick[]
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  color       String?
  createdAt   DateTime @default(now())

  tools       ToolCategory[]
}

model Industry {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  createdAt   DateTime @default(now())

  tools       ToolIndustry[]
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique

  tools ToolTag[]
}

model ToolCategory {
  toolId     String
  categoryId String
  tool       Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([toolId, categoryId])
}

model ToolIndustry {
  toolId     String
  industryId String
  tool       Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
  industry   Industry @relation(fields: [industryId], references: [id], onDelete: Cascade)

  @@id([toolId, industryId])
}

model ToolTag {
  toolId String
  tagId  String
  tool   Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([toolId, tagId])
}

model PricingPlan {
  id        String   @id @default(cuid())
  toolId    String
  name      String
  price     Float?
  currency  String   @default("USD")
  period    String?
  features  String
  isPopular Boolean  @default(false)
  tool      Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
}

model Feature {
  id          String @id @default(cuid())
  toolId      String
  name        String
  description String?
  icon        String?
  tool        Tool   @relation(fields: [toolId], references: [id], onDelete: Cascade)
}

model UseCase {
  id          String @id @default(cuid())
  toolId      String
  title       String
  description String
  icon        String?
  tool        Tool   @relation(fields: [toolId], references: [id], onDelete: Cascade)
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())

  reviews   Review[]
}

model Review {
  id           String   @id @default(cuid())
  toolId       String
  userId       String
  rating       Int
  title        String?
  content      String?
  helpfulCount Int      @default(0)
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())

  tool         Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)
  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ToolView {
  id        String   @id @default(cuid())
  toolId    String
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  tool      Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)
}

model ToolClick {
  id        String   @id @default(cuid())
  toolId    String
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  tool      Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)
}

model McpServer {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  category        String
  description     String
  longDescription String?
  icon            String?
  difficulty      String   @default("Intermediate")
  popularityRank  Int      @default(0)
  githubStars     String?
  githubUrl       String?
  websiteUrl      String?
  useCases        String?
  pros            String?
  cons            String?
  bestFor         String?
  setupGuide      String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
